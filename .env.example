# SkillOpt_Lite public-release env template.
#
# Copy to .env and fill in the section for the auth mode you want to use.
# `env.sh` auto-sources .env if present.
#
# Pick ONE of the three modes below by setting SKILLOPT_AUTH_MODE, then
# fill in the matching variables.
#
# ───────────────────────────────────────────────────────────────────────────
SKILLOPT_AUTH_MODE=azure_cli   # azure_cli | azure_key | openai
# ───────────────────────────────────────────────────────────────────────────

# ── Mode 1: azure_cli  (Azure OpenAI + AAD, requires `az login`) ────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# (no key needed — token acquired from `az account get-access-token`)

# ── Mode 2: azure_key  (Azure OpenAI + api key) ─────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_API_KEY=sk-azure-...

# ── Mode 3: openai     (Official OpenAI or any OpenAI-compatible endpoint) ──
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1        # override for e.g. vLLM
