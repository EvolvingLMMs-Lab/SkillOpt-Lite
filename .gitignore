# SkillOpt public release .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build/
dist/

# OS / editor
.DS_Store
.vscode/
.idea/

# Local secrets & runtime state
.env
env.local.sh

# Per-env workspaces (auto-generated by run.sh / make_samples.py)
copilot_example/*/workspace/
copilot_example/*/workspaces/
copilot_example/*/workspace_legacy_backup/
copilot_example/*/.skillopt/

# Materialized data (hydrated via data/download.py)
data/searchqa/
data/docvqa/
data/docvqa_images/
data/alfworld/
data/officeqa/
data/spreadsheetbench/
data/livemath/

# Run artifacts
outputs/
logs/
